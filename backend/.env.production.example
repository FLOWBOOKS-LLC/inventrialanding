PORT=4000
FRONTEND_ORIGIN=https://your-frontend-domain.com

# Base URL (Remita Connect PRODUCTION)
REMITA_BASE_URL=https://api.remita.net

# Remita Connect credentials
REMITA_PUBLIC_KEY=
REMITA_SECRET_KEY=

# Live Legacy Credentials (Invoice / RRR fallback)
REMITA_MERCHANT_ID=
REMITA_SERVICE_TYPE_ID=
REMITA_API_KEY=
REMITA_CALLBACK_URL=https://your-frontend-domain.com/register-partner

# Optional: UAAS token (some Remita APIs require Bearer token)
REMITA_API_TOKEN=
REMITA_TOKEN_URL=https://login.remita.net/remita/exapp/api/v1/send/api/uaasvc/uaa/token

# Legacy endpoints
REMITA_INIT_PATH=/remita/exapp/api/v1/send/api/echannelsvc/merchant/api/paymentinit
REMITA_STATUS_PATH=/remita/exapp/api/v1/send/api/echannelsvc/merchant/{merchantId}/{rrr}/status.reg

# Remita Connect endpoints
REMITA_CONNECT_INIT_PATH=/payment/v1/payments
REMITA_CONNECT_VERIFY_PATH=/payment/v1/payments/{reference}
REMITA_CURRENCY=NGN

# --- Calendly (Book a call → webhook → email) ---
# Register webhook in Calendly: POST https://api.calendly.com/webhook_subscriptions
# Callback: https://YOUR_PUBLIC_API/api/integrations/calendly/webhook
# CALENDLY_WEBHOOK_SIGNING_KEY=<same secret you set as signing_key on the subscription>
# CALENDLY_NOTIFY_EMAIL=you@example.com
# RESEND_API_KEY=re_xxx
# CALENDLY_EMAIL_FROM=Flowbooks <bookings@your-verified-domain.com>
# Optional: enrich notifications via Calendly API
# CALENDLY_PERSONAL_ACCESS_TOKEN=
